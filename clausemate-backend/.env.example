# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clausemate

# Redis
# PRODUCTION REQUIREMENT: Redis MUST run with AOF persistence enabled.
# See redis.conf in this repository. Without AOF, a Redis restart
# permanently loses all queued analysis jobs and leaves credit_reservations
# stuck in "reserved" state. The startup check logs CRITICAL if AOF is off.
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRY=24h

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=anthropic
LLM_MODEL_OPENAI=gpt-4o
LLM_MODEL_ANTHROPIC=claude-sonnet-4-20250514

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=clausemate-contracts
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Rate Limiting
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_ANALYSIS_MAX=10
RATE_LIMIT_ANALYSIS_WINDOW_MS=60000

# File Upload
MAX_FILE_SIZE_MB=10

# Analysis Worker Tuning (optional — defaults shown)
# ANALYSIS_MAX_CONCURRENT_PER_USER=3
# ANALYSIS_MAX_QUEUE_DEPTH=100
# ANALYSIS_WORKER_CONCURRENCY=3
# ANALYSIS_JOB_TIMEOUT_MS=1200000        # 20 minutes
# ANALYSIS_WORKER_LOCK_DURATION_MS=300000 # 5 minutes
# ANALYSIS_WORKER_STALLED_INTERVAL_MS=60000
# ANALYSIS_WORKER_MAX_STALLED_COUNT=2

# Stale Reservation Sweeper
# Releases credits for reservations orphaned by a Redis restart or job loss.
# ANALYSIS_STALE_SWEEP_INTERVAL_MS=3600000    # Run every hour (default)
# ANALYSIS_STALE_RESERVATION_CUTOFF_MS=7200000 # Reservations older than 2h are stale (default: jobTimeout × 3 attempts × 2)
